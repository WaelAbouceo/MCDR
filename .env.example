# ─── MCDR CX Platform — Environment Configuration ────────────
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.

# ─── Required in production ───────────────────────────────────
ENVIRONMENT=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql+asyncpg://mcdr:CHANGE_ME@localhost:5432/mcdr
CUSTOMER_DB_URL=postgresql+asyncpg://mcdr_readonly:CHANGE_ME@localhost:5433/mcdr_customers
# DATABASE_SSL=verify-full

# SQLite paths (development only — ignored when using PostgreSQL)
MCDR_CORE_DB_PATH=mcdr_mock/mcdr_core.db
MCDR_MOBILE_DB_PATH=mcdr_mock/mcdr_mobile.db
MCDR_CX_DB_PATH=mcdr_mock/mcdr_cx.db

# ─── Auth ─────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── CORS (comma-separated origins) ──────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Infrastructure ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
